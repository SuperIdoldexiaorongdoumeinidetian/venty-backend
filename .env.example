# --- Server ---
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# --- Datenbank (muss zu docker-compose.yml passen) ---
DATABASE_URL=postgresql://venty:venty@localhost:5432/venty?schema=public

# --- Auth ---
# Mind. 32 Zeichen, in Produktion z. B. mit `openssl rand -base64 48` erzeugen
JWT_SECRET=change-me-to-a-long-random-secret-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
# Max. Requests pro Minute auf /auth/* (pro IP)
AUTH_RATE_LIMIT_MAX=10

# --- CORS ---
# localhost + private LAN-IPs (Expo Dev) sind immer erlaubt.
# Zusätzliche Origins kommasepariert, z. B. https://app.venty.example
CORS_EXTRA_ORIGINS=
